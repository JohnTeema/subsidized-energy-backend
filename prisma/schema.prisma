generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  walletAddress    String   @unique
  emailVerified    Boolean  @default(false)
  verificationCode String?
  codeExpiresAt    DateTime?
  resetCode        String?
  resetCodeExpiresAt DateTime?
  resetAttempts    Int      @default(0)
  resetWindowStart DateTime?
  createdAt        DateTime @default(now())
  srePoints        Float    @default(0)

  inverters        InverterConnection[]
  readings         EnergyReading[]
  srePointsLogs    SrePointsLog[]
}

model InverterConnection {
  id          String   @id @default(cuid())
  userId      String
  inverterId  String   @unique
  brand       String
  apiKey      String   @default("")
  credentials String   @default("{}")
  isActive         Boolean   @default(true)
  lastRecordedDate DateTime?
  deviceSerial     String?
  plantName        String?
  location         String?
  createdAt        DateTime  @default(now())

  user     User            @relation(fields: [userId], references: [id])
  readings EnergyReading[]
}

model EnergyReading {
  id              String   @id @default(cuid())
  inverterId      String
  userId          String
  kwhProduced     Float
  readingType     String   @default("snapshot")
  intervalStart   DateTime
  intervalEnd     DateTime
  rawDataHash     String
  validated       Boolean  @default(false)
  validationError String?
  txHash          String?
  onChainRecordId Int?
  subMinted       Float?
  sreMinted       Float?
  panelPower      Float?
  batteryCapacity Float?
  batteryVoltage  Float?
  epvTotal        Float?
  epvToday        Float?
  createdAt       DateTime @default(now())

  inverter InverterConnection @relation(fields: [inverterId], references: [id])
  user     User               @relation(fields: [userId], references: [id])
}

model SrePointsLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model EsgBuyer {
  id               String   @id @default(cuid())
  organizationName String
  companyId        String
  country          String
  industry         String
  contactEmail     String
  walletAddress    String   @unique
  annualTarget     Float?
  createdAt        DateTime @default(now())
}
