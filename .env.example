# Auth
JWT_SECRET=your-strong-random-jwt-secret
CREDENTIALS_SECRET=your-strong-random-credentials-secret

# Base Sepolia
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
DEPLOYER_PRIVATE_KEY=0xyour_ethereum_private_key
SUB_TOKEN_ADDRESS=0x34a42157C86489E102bC7F611c0d05696FA45682
SRE_TOKEN_ADDRESS=0xB60fbCc17a0aeb405bC55a816ed39B2ff6480ABF
ENERGY_REGISTRY_ADDRESS=0x21AE62E009f04259173C0f08ED5650dE53bD9CE7

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=your_base58_solana_private_key
SOLANA_ENERGY_REGISTRY=E93p3yX6mxswv1yBn6gcZvsPCqckyupUVQKuk6YLNyYR

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key

# Feature flags
ACTIVE_CHAINS=base,solana
ALLOW_MOCK_INVERTERS=false

# One-time migration trigger (set to "true" only when needed, then remove)
# RUN_RETROACTIVE_BONUS=false

# Server port (set automatically by Render)
# PORT=3000
